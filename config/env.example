# ============================================================
# AUT_SOC - Configuration Environment Variables
# ============================================================

# n8n Configuration
N8N_HOST=192.168.118.64
N8N_PORT=5678
N8N_PROTOCOL=http

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soc_database
DB_USER=soc_user
DB_PASSWORD=secure_password_change_me

# QRadar SIEM Configuration
QRADAR_HOST=192.168.71.54
QRADAR_API_KEY=your_qradar_api_key_here

# External APIs
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
GREYNOISE_API_KEY=your_greynoise_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Telegram Notification
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Ollama LLM Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_JUNIOR=qwen2.5:14b
OLLAMA_MODEL_SENIOR=deepseek-r1:14b

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=/var/log/aut_soc.log

# Scheduling
WORKFLOW_SCHEDULE=0 * * * *
WORKFLOW_TIMEZONE=America/Bogota
